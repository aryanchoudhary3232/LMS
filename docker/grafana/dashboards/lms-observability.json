{
  "id": null,
  "uid": "lms-observability",
  "title": "LMS Deployed Observability (Render + Vercel)",
  "tags": ["lms", "performance", "latency"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 3,
  "refresh": "15s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "type": "stat",
      "title": "HTTP RPS",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(lms_http_requests_total{env=\"prod\",source=\"render\"}[1m]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "HTTP Error Rate (4xx/5xx)",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(lms_http_requests_total{env=\"prod\",source=\"render\",status_class=~\"4xx|5xx\"}[5m])) / clamp_min(sum(rate(lms_http_requests_total{env=\"prod\",source=\"render\"}[5m])), 1)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2
        }
      }
    },
    {
      "type": "stat",
      "title": "In-flight Requests",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(lms_http_inflight_requests{env=\"prod\",source=\"render\"})",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Slow Requests / min",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(lms_slow_requests_total{env=\"prod\",source=\"render\"}[1m]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Frontend JS Errors / min",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(lms_frontend_js_errors_total{env=\"prod\",source=\"render\"}[1m]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Uptime Probes Healthy",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(probe_success{job=\"blackbox_http\",instance=~\"https://lms-wine-nine.vercel.app|https://lms-bx7u.onrender.com/health|https://lms-bx7u.onrender.com/metrics\"})",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "API Latency p50/p95/p99 (backend)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(lms_http_request_duration_seconds_bucket{env=\"prod\",source=\"render\"}[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(lms_http_request_duration_seconds_bucket{env=\"prod\",source=\"render\"}[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(lms_http_request_duration_seconds_bucket{env=\"prod\",source=\"render\"}[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "All Endpoints by Latency (p95)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (route, le) (rate(lms_http_request_duration_seconds_bucket{env=\"prod\",source=\"render\"}[5m])))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Cache Hit Ratio",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(lms_cache_events_total{env=\"prod\",source=\"render\",operation=\"lookup\",result=\"hit\"}[5m])) / clamp_min(sum(rate(lms_cache_events_total{env=\"prod\",source=\"render\",operation=\"lookup\",result=~\"hit|miss\"}[5m])), 1)",
          "legendFormat": "hit ratio",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Rate Limiter Decisions",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (outcome, backend) (rate(lms_rate_limiter_events_total{env=\"prod\",source=\"render\"}[5m]))",
          "legendFormat": "{{backend}} - {{outcome}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Frontend API Latency p95",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(lms_frontend_api_latency_seconds_bucket{env=\"prod\",source=\"render\"}[5m])))",
          "legendFormat": "browser p95",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Core Web Vitals (ms)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.75, sum by (metric_name, le) (rate(lms_frontend_web_vital_ms_bucket{env=\"prod\",source=\"render\"}[5m])))",
          "legendFormat": "{{metric_name}} p75",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Route Transition p95",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "topk(10, histogram_quantile(0.95, sum by (route, le) (rate(lms_frontend_route_transition_seconds_bucket{env=\"prod\",source=\"render\"}[5m]))))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Top API Routes by RPS",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "topk(15, sum by (route) (rate(lms_http_requests_total{env=\"prod\",source=\"render\"}[5m])))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Route Error Rate by Status Class",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (route, status_class) (rate(lms_http_requests_total{env=\"prod\",source=\"render\",status_class=~\"4xx|5xx\"}[5m])) / clamp_min(sum by (route) (rate(lms_http_requests_total{env=\"prod\",source=\"render\"}[5m])), 1)",
          "legendFormat": "{{route}} {{status_class}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Probe Success by Deployed URL",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 36 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "probe_success{job=\"blackbox_http\",instance=~\"https://lms-wine-nine.vercel.app|https://lms-bx7u.onrender.com/health|https://lms-bx7u.onrender.com/metrics\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Probe Duration by Deployed URL",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 36 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "probe_duration_seconds{job=\"blackbox_http\",instance=~\"https://lms-wine-nine.vercel.app|https://lms-bx7u.onrender.com/health|https://lms-bx7u.onrender.com/metrics\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Probe HTTP Status by Deployed URL",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 36 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "probe_http_status_code{job=\"blackbox_http\",instance=~\"https://lms-wine-nine.vercel.app|https://lms-bx7u.onrender.com/health|https://lms-bx7u.onrender.com/metrics\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Frontend Routes Seen (24h)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 44 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "topk(50, sum by (route) (increase(lms_frontend_route_transition_seconds_count{env=\"prod\",source=\"render\"}[24h])))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "table",
      "title": "Configured Backend Endpoints (Catalog)",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 52 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (method, route) (lms_backend_endpoint_catalog{env=\"prod\",source=\"render\"})",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "showHeader": true
      }
    }
  ]
}
